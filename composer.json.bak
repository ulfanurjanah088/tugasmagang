{
    "name": "doret/cuti-management",
    "description": "Sistem Manajemen Cuti Karyawan doret.id",
    "type": "project",
    "require": {
        "google/cloud-firestore": "^1.0",
        "kreait/firebase-php": "5.10.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
